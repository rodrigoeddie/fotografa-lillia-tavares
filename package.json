{
  "name": "fotografa-lillia-tavares",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=3072 nuxt build",
    "dev": "TMPDIR=/tmp nuxt dev",
    "generate": "NODE_OPTIONS=--max-old-space-size=3072 nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "migrate:local": "bun scripts/apply-all-migrations.ts --local",
    "migrate:prod": "bun scripts/apply-all-migrations.ts --remote",
    "migrate:local:fresh": "bun scripts/apply-all-migrations.ts --local --fresh",
    "migrate:prod:fresh": "bun scripts/apply-all-migrations.ts --remote --fresh",
    "r2:cors": "wrangler r2 bucket cors set fotografa-lillia-ensaios --file r2-cors.json",
    "test:push": "bun run build && npx wrangler pages dev dist",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:apply:local": "bun scripts/apply-drizzle-migrations.ts --local",
    "db:apply:prod": "bun scripts/apply-drizzle-migrations.ts --remote",
    "db:backup": "bun scripts/db-backup.ts",
    "db:restore": "bun scripts/db-restore.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@iconify-json/lucide": "^1.2.105",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/scripts": "^0.13.4",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/seo": "^5.1.3",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.1",
    "cssnano": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3",
    "es-module-shims": "^2.8.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.4.7",
    "nuxt-easy-lightbox": "^1.1.0",
    "sass": "^1.99.0",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.2",
    "nuxt-schema-org": "^5.0.10",
    "postcss": "^8.5.13",
    "postcss-import": "^16.1.1",
    "sharp": "^0.33.5",
    "sweetalert2": "^11.26.24",
    "swiper": "^12.1.4",
    "unenv": "2.0.0-rc.24",
    "wrangler": "^4.97.0",
    "zod": "^4.4.3"
  }
}
