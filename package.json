    "@nuxt/scripts": "^0.13.2",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/seo": "^3.4.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
